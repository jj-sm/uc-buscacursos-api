# Universal API Environment Configuration
# Copy this file to .env and adjust values for your environment
# See API_TEMPLATE_GUIDE.md for detailed setup instructions

# =============================================================================
# BUSCACURSOS DATABASE CONFIGURATION
# =============================================================================

# SQLite database containing semester_YYYY_N tables (buscacursos data)
# Populated automatically via the update check from jj-sm/buscacursos-dl-jj-sm
COURSES_DATABASE_URL=sqlite:///./data/courses.sqlite

# Optional GitHub Personal Access Token to avoid API rate limits when checking
# for new semester releases.  Needs only public repo read access.
GITHUB_TOKEN=

# How often (in seconds) to check GitHub for new semester releases.
# Default: 2592000 (30 days). Can also be changed at runtime via
# POST /admin/courses/update-frequency
COURSES_UPDATE_INTERVAL_SECONDS=2592000

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug mode (0=disabled, 1=enabled)
# When DEBUG=1, API key validation is skipped and all endpoints are accessible
# ALWAYS set DEBUG=0 in production
DEBUG=0

# Enable C++ extensions (0=disabled, 1=enabled)
# Only needed if using CPP helpers
DEV_CPP=1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Main data database URL
# Examples:
#   SQLite:      sqlite:///./data/api_data.db
#   PostgreSQL:  postgresql://user:password@localhost/api_db
#   MySQL:       mysql+pymysql://user:password@localhost/api_db
DATABASE_URL=sqlite:///./data/api_data.db

# Authentication database URL (for API keys)
# This stores API keys, tiers, and rate limiting data
# Keep this secure and separate from your main data
AUTH_DATABASE_URL=sqlite:///./auth_data/api_keys.db

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# API server bind address
# Use 0.0.0.0 to bind to all interfaces, 127.0.0.1 for localhost only
API_URL=0.0.0.0

# API server port
API_PORT=8000

# URL prefix for all API endpoints
# Example: /api/v1/ means endpoints will be at /api/v1/courses/, etc.
# Leave empty for no prefix
URL_PREFIX=

# CORS allowed origins (comma-separated)
# Use * for development only. Specify exact origins in production
CORS_ORIGINS=*

# =============================================================================
# RATE LIMITING & AUTHENTICATION
# =============================================================================

# API Tier Configuration
# Defines request limits and burst allowance per tier

# Free tier (default tier for new keys)
FREE_TIER_RATE_LIMIT=10
FREE_TIER_BURST_LIMIT=20
FREE_TIER_DESCRIPTION=Free tier with basic access

# Pro tier (recommended for production use)
PRO_TIER_RATE_LIMIT=100
PRO_TIER_BURST_LIMIT=200
PRO_TIER_DESCRIPTION=Professional tier with higher limits

# Premium tier (for high-traffic applications)
PREMIUM_TIER_RATE_LIMIT=1000
PREMIUM_TIER_BURST_LIMIT=2000
PREMIUM_TIER_DESCRIPTION=Premium tier for scaling applications

# Enterprise tier (unlimited requests)
ENTERPRISE_TIER_RATE_LIMIT=unlimited
ENTERPRISE_TIER_BURST_LIMIT=unlimited
ENTERPRISE_TIER_DESCRIPTION=Enterprise tier with unlimited requests

# NOTE: These environment variables can override TIER_CONFIG in auth_models.py
# if you implement env-based configuration loading

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# OBSERVABILITY (OPTIONAL)
# =============================================================================

# Enable Grafana/Tempo/Prometheus/Loki observability pipeline
# Set to 1 to turn on tracing, metrics, and log correlation
ENABLE_OBSERVABILITY=0

# OTLP gRPC endpoint for Tempo/OTel collector (e.g., http://tempo:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name used in traces/logs
OTEL_SERVICE_NAME=uc-buscacursos-api

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Number of Uvicorn worker processes
# Set based on your server's CPU cores (typically CPU cores * 2)
UVICORN_WORKERS=4

# Maximum number of concurrent connections per worker
UVICORN_WORKER_CONNECTIONS=1000

# Enable auto-reload in development (0=disabled, 1=enabled)
# Only use in development, never in production
UVICORN_RELOAD=0
